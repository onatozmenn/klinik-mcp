# Optional: an openFDA API key raises the rate limits (not required to run).
# Get one free at https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# Optional: an NCBI API key raises PubMed rate limits (not required to run).
# Get one free at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Transport configuration (used by `python -m health_mcp`)
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
